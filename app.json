{
  "expo": {
    "name": "Parth Gautam Foundation",
    "slug": "parth-gautam-foundation",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/PG-App-Logo.webp",
    "scheme": "frontend",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Show nearby programs and services",
        "NSCameraUsageDescription": "Take photos for issue reporting",
        "NSMicrophoneUsageDescription": "Voice commands for AI assistant",
        "NSSpeechRecognitionUsageDescription": "Voice input for AI assistant"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/PG-App-Logo.webp",
        "backgroundColor": "#3B82F6"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "edgeToEdgeEnabled": true,
      "package": "com.theanasiqbal.pgfoundation"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/PG-App-Logo.webp"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow access to show nearby programs"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/PG-App-Logo.webp",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F7983E"
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5eb78bf9-0f25-4913-ab8a-fd3928560855"
      }
    },
    "owner": "shahahmad12s-organization"
  }
}